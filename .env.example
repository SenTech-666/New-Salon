# ============================================================
# .env.example — скопируйте в .env.local и заполните значения
# ============================================================

# --- Clerk (аутентификация) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
# Service role — ТОЛЬКО для сервера (api routes, webhooks). Никогда не
# светить на клиенте и не префиксовать NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Stripe (платежи) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Resend (email) ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Aptio <noreply@yourdomain.com>"

# --- Upstash Redis (rate limiting на /api/*) ---
# Опционально на старте — если не задано, rate limiting просто
# отключается (см. lib/rate-limit.ts), приложение не упадёт.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Внутренний API (server-to-server интеграции, см. lib/api-auth.ts) ---
# Соль для хеширования API-ключей перед сохранением в БД (api_keys.key_hash).
API_KEY_HASH_SALT=change-me-to-a-random-string

# --- Приложение ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Логирование (опционально) ---
# Если задано — lib/logger.ts будет дублировать error-логи во внешний
# сервис (Sentry/Logtail/Axiom). Если не задано — просто console.*.
LOG_DRAIN_URL=
LOG_DRAIN_TOKEN=

# --- E2E тесты (Playwright) ---
PLAYWRIGHT_BASE_URL=http://localhost:3000
# Токен тестового пользователя для обхода Clerk в защищённых e2e тестах.
# См. https://clerk.com/docs/testing/overview — заполняется только в CI.
E2E_TEST_USER_TOKEN=
E2E_API_KEY=
